generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Retailer — one row per deployed instance (seeded at setup time)
// ---------------------------------------------------------------------------
model Retailer {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  logoUrl      String?
  primaryColor String    @default("#1a1a2e")
  accentColor  String    @default("#e94560")
  contactEmail String
  createdAt    DateTime  @default(now())

  products Product[]
  sessions Session[]
}

// ---------------------------------------------------------------------------
// Product — catalog item belonging to a retailer
// ---------------------------------------------------------------------------
model Product {
  id           String          @id @default(cuid())
  retailerId   String
  retailer     Retailer        @relation(fields: [retailerId], references: [id])
  sku          String
  name         String
  description  String
  category     ProductCategory
  room         RoomType[]
  priceUsd     Int             // stored in cents
  imageUrl     String
  thumbnailUrl String
  styleIds     String[]
  colorFamily  String[]
  materialTags String[]
  dimensions   Json?           // { w: number, h: number, d: number } in inches
  inStock      Boolean         @default(true)

  swipes    Swipe[]
  planItems PlanItem[]

  @@index([retailerId, category])
}

// ---------------------------------------------------------------------------
// Session — one per shopper visit; the core state machine
// ---------------------------------------------------------------------------
model Session {
  id            String     @id @default(cuid())
  retailerId    String
  retailer      Retailer   @relation(fields: [retailerId], references: [id])
  shopperName   String?
  email         String?
  address       String?
  addressMeta   Json?      // { beds: 2, baths: 2, sqft: null, source: "stub" }
  consentGiven  Boolean    @default(false)
  selectedRooms RoomType[]
  designStyle   String?
  colorPalette  String[]
  budgetCents   Json?      // { LIVING_ROOM: 300000, BEDROOM: 150000 }
  currentStep   StepName   @default(PROFILE)
  completedAt   DateTime?
  resumeToken   String     @unique @default(cuid())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  swipes Swipe[]
  plans  Plan[]

  @@index([email])
  @@index([resumeToken])
  @@index([retailerId])
}

// ---------------------------------------------------------------------------
// Swipe — individual like/dislike signal per session per product
// ---------------------------------------------------------------------------
model Swipe {
  id        String         @id @default(cuid())
  sessionId String
  session   Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  room      RoomType
  direction SwipeDirection
  createdAt DateTime       @default(now())

  @@unique([sessionId, productId])
  @@index([sessionId, room, direction])
}

// ---------------------------------------------------------------------------
// Plan — generated room plan; may be revised multiple times
// ---------------------------------------------------------------------------
model Plan {
  id             String   @id @default(cuid())
  sessionId      String
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  shareToken     String   @unique @default(cuid())
  version        Int      @default(1)
  styleRationale String
  layoutJson     Json     // RoomLayout[]
  totalCents     Int
  refinements    Json     @default("[]") // array of { instruction, appliedAt }
  emailedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items PlanItem[]

  @@index([shareToken])
  @@index([sessionId])
}

// ---------------------------------------------------------------------------
// PlanItem — one product line-item within a plan
// ---------------------------------------------------------------------------
model PlanItem {
  id         String   @id @default(cuid())
  planId     String
  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  room       RoomType
  quantity   Int      @default(1)
  noteFromAI String?
  position   Json?    // { x, y, w, h } on 12x8 grid

  @@index([planId, room])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
enum RoomType {
  LIVING_ROOM
  BEDROOM
  DINING_ROOM
  HOME_OFFICE
  NURSERY
}

enum ProductCategory {
  SOFA
  ARMCHAIR
  COFFEE_TABLE
  SIDE_TABLE
  DINING_TABLE
  DINING_CHAIR
  BED_FRAME
  DRESSER
  BOOKSHELF
  DESK
  DESK_CHAIR
  FLOOR_LAMP
  TABLE_LAMP
  RUG
  ARTWORK
  MIRROR
  STORAGE
  ACCENT_PIECE
}

enum StepName {
  PROFILE
  ROOMS
  STYLE
  BUDGET
  RECOMMENDATIONS
  PLAN
  REFINE
  COMPLETE
}

enum SwipeDirection {
  LIKE
  DISLIKE
  SKIP
}
